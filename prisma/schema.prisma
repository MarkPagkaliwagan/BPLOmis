generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  username  String   @unique
  email     String   @unique
  phone     String?
  password  String
  role      Role     @default(USER)
  status    String   @default("PENDING")    // default status
  createdAt DateTime @default(now())
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
}
